  "ob_done_s1": {
    "message": "Done! You know the basics of AsideNotes. You can restart the guide anytime from the settings panel."
  },
  "ob_done_s2": {
    "message": "Great! You now know how to manage tasks with due dates and recurrence. Find more guide stages in settings."
  },
  "ob_done_s3": {
    "message": "Focus modes mastered. Alt+Z and Alt+M are shortcuts worth having in your muscle memory."
  },
  "ob_done_s4": {
    "message": "Guide complete. You now know all the key features of AsideNotes. Go get things done!"
  },
  "ob_panel_title": {
    "message": "Guide"
  },
  "ob_s1_1": {
    "message": "Type something and press Enter. Start with ! to create a task instead of a note."
  },
  "ob_s1_2": {
    "message": "Your notes and tasks live here. Click any item to open it."
  },
  "ob_s1_2_empty": {
    "message": "No notes yet. Go back to step 1 and add your first one — type something in the field above and press Enter."
  },
  "ob_s1_3": {
    "message": "Write here. Markdown works: # heading, - list, --- divider."
  },
  "ob_s1_4": {
    "message": "Type / to see all block types: headings, lists, callouts, code and more."
  },
  "ob_s1_5": {
    "message": "There's also a quick capture mode — a separate popup that opens without having to open the editor. Type a note or task and get back to what you were doing."
  },
  "ob_s1_6": {
    "message": "Alt+Shift+S opens quick capture from any browser tab. You can close and reopen AsideNotes whenever you want — Alt+Shift+Q."
  },
  "ob_s2_1": {
    "message": "Type !call mom tomorrow 6pm and Enter — creates a task with a due date and alarm."
  },
  "ob_s2_2": {
    "message": "Click a task in the list to open it in the editor."
  },
  "ob_s2_2_empty": {
    "message": "No tasks yet. Go back to step 1 — type !something in the field above and press Enter."
  },
  "ob_s2_3": {
    "message": "Click the due date field to set date, time and reminder in one place."
  },
  "ob_s2_4_rec": {
    "message": "At the bottom of the picker you can set recurrence — daily, weekly, monthly, yearly, or specific days of the week."
  },
  "ob_s2_5": {
    "message": "Tasks sort themselves automatically: Overdue, Today, Tomorrow, This week and later."
  },
  "ob_s3_1": {
    "message": "Press Alt+Z — zen mode shows only what matters today and reduces visual noise."
  },
  "ob_s3_2": {
    "message": "Alt+Z again exits zen mode and returns to the normal view."
  },
  "ob_s3_3": {
    "message": "Press Alt+M — the editor takes up the full panel. Great for longer writing."
  },
  "ob_s4_1": {
    "message": "Add a tag to a note — click + add tag below the editor. Filter your list by tags."
  },
  "ob_s4_2": {
    "message": "Filter notes and tasks by tags, type and due date."
  },
  "ob_s4_3": {
    "message": "Full keyboard shortcut reference — useful once you start using the keyboard more."
  },
  "ob_s4_4": {
    "message": "Your data is local — zero cloud, zero trackers. Export whenever you want."
  },
