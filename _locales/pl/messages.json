  "ob_done_s1": {
    "message": "Gotowe! Znasz już podstawy AsideNotes. Przewodnik możesz uruchomić ponownie w dowolnym momencie z panelu ustawień."
  },
  "ob_done_s2": {
    "message": "Świetnie! Wiesz już jak zarządzać zadaniami z terminami i powtarzaniem. Kolejne etapy przewodnika znajdziesz w ustawieniach."
  },
  "ob_done_s3": {
    "message": "Tryby skupienia opanowane. Alt+Z i Alt+M to skróty które warto mieć w pamięci mięśniowej."
  },
  "ob_done_s4": {
    "message": "Przewodnik ukończony. Znasz teraz wszystkie kluczowe funkcje AsideNotes. Do dzieła!"
  },
  "ob_panel_title": {
    "message": "Przewodnik"
  },
  "ob_s1_1": {
    "message": "Wpisz coś i wciśnij Enter. Dodaj ! na początku żeby utworzyć zadanie zamiast notatki."
  },
  "ob_s1_2": {
    "message": "Tu są twoje notatki i zadania. Kliknij element żeby go otworzyć."
  },
  "ob_s1_2_empty": {
    "message": "Jeszcze nie masz notatek. Wróć do kroku 1 i dodaj pierwszą — wpisz coś w polu wyżej i wciśnij Enter."
  },
  "ob_s1_3": {
    "message": "Tu piszesz. Markdown działa: # nagłówek, - lista, **bold**, *italic*, ~~strike~~, `kod`, --- separator."
  },
  "ob_s1_4": {
    "message": "Wpisz / żeby zobaczyć wszystkie typy bloków: nagłówki, listy, callout, kod i więcej."
  },
  "ob_s1_5": {
    "message": "Jest też tryb szybkiego dodawania — osobne okienko bez konieczności otwierania edytora. Wpisujesz notatkę lub zadanie i wracasz do pracy."
  },
  "ob_s1_6": {
    "message": "Alt+Shift+S otwiera szybkie dodawanie z dowolnej karty przeglądarki. Możesz zamknąć i otworzyć AsideNotes kiedy chcesz — Alt+Shift+Q."
  },
  "ob_s2_1": {
    "message": "Wpisz !zadzwonić do mamy jutro 18:00 i Enter — tworzy zadanie z terminem i alarmem."
  },
  "ob_s2_2": {
    "message": "Kliknij zadanie na liście żeby je otworzyć w edytorze."
  },
  "ob_s2_2_empty": {
    "message": "Nie masz jeszcze żadnych zadań. Wróć do kroku 1 — wpisz !coś w polu powyżej i wciśnij Enter."
  },
  "ob_s2_3": {
    "message": "Kliknij pole terminu żeby ustawić datę, godzinę i przypomnienie w jednym miejscu."
  },
  "ob_s2_4_rec": {
    "message": "Na dole pickera możesz ustawić powtarzanie — codziennie, co tydzień, co miesiąc, co rok lub wybrane dni tygodnia."
  },
  "ob_s2_5": {
    "message": "Zadania układają się automatycznie: Zaległe, Dziś, Jutro, Ten tydzień i dalej."
  },
  "ob_s3_1": {
    "message": "Wciśnij Alt+Z — zen mode pokazuje tylko to co ważne dziś i redukuje bodźce wizualne."
  },
  "ob_s3_2": {
    "message": "Alt+Z jeszcze raz wyłącza zen mode i wraca do normalnego widoku."
  },
  "ob_s3_3": {
    "message": "Wciśnij Alt+M — edytor zajmuje cały ekran. Idealne do dłuższego pisania."
  },
  "ob_s4_1": {
    "message": "Dodaj tag do notatki — kliknij + dodaj tag pod edytorem. Filtruj listę po tagach."
  },
  "ob_s4_2": {
    "message": "Filtruj notatki i zadania po tagach, typie i terminie."
  },
  "ob_s4_3": {
    "message": "Pełna lista skrótów w dwóch zakładkach: Ogólne i Edytor — przydaje się gdy zaczniesz używać klawiatury więcej niż myszy."
  },
  "ob_s4_4": {
    "message": "Twoje dane są lokalne — zero chmury, zero trackerów. Eksportuj kiedy chcesz."
  },
