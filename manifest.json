{
  "manifest_version": 2,
  "name": "Notatnik by Tyler",
  "version": "1.0.1",
  "description": "Lekki notatnik w panelu bocznym przeglądarki",

  "browser_specific_settings": {
    "gecko": {
      "id": "notatnik-by-tyler@example.com",
      "data_collection_permissions": {
        "description": "Ten dodatek nie zbiera żadnych danych użytkownika ani danych telemetrycznych. Wszystkie dane (notatki) są przechowywane lokalnie w przeglądarce użytkownika.",
        "required": ["none"]
      }
    }
  },

  "icons": {
    "64": "assets/icons/mdi--event-note.png"
  },

  "sidebar_action": {
    "default_title": "Notatnik by Tyler",
    "default_panel": "sidebar.html",
    "default_icon": {
      "64": "assets/icons/mdi--event-note.png"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "commands": {
    "toggle-sidebar": { "suggested_key": { "default": "Alt+Shift+Q" } }
  },
  "permissions": ["storage"]
}
